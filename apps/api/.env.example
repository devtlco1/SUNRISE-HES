APP_ENV=development
PROJECT_NAME=sunrise-hes-platform
COMPANY_NAME=Abraj Al Anwar Contracting, General Trading and Commercial Agencies Company
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://sunrise:sunrise@postgres:5432/sunrise_hes
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_STREAM_NAME=hes:dispatch
REDIS_QUEUE_CONSUMER_GROUP_NAME=hes-worker-group
REDIS_QUEUE_CLAIM_TIMEOUT_SECONDS=300
REDIS_QUEUE_STALE_CLAIM_THRESHOLD_SECONDS=300
REDIS_QUEUE_DEAD_LETTER_STREAM_NAME=
REDIS_QUEUE_VALIDATE_ON_STARTUP=false
REDIS_QUEUE_ENSURE_STREAM_ON_STARTUP=false
REDIS_QUEUE_ENSURE_CONSUMER_GROUP_ON_STARTUP=false
QUEUE_BACKEND=mock
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-me-before-production-with-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=sunrise-hes-platform
INTERNAL_API_TOKEN=sunrise-internal-token-change-me
BOOTSTRAP_SUPER_ADMIN_USERNAME=admin
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_SUPER_ADMIN_FULL_NAME=Platform Super Admin
BOOTSTRAP_SUPER_ADMIN_PASSWORD=ChangeThisPassword123!
